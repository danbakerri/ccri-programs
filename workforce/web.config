<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Block direct access to JSON files -->
    <security>
      <requestFiltering>
        <fileExtensions>
          <add fileExtension=".json" allowed="false" />
          <!-- Optional: Block backup files -->
          <add fileExtension=".bak" allowed="false" />
          <add fileExtension=".backup" allowed="false" />
          <add fileExtension=".old" allowed="false" />
          <add fileExtension=".tmp" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>
</configuration>
