<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Block all direct web access to cache directory -->
    <security>
      <authorization>
        <remove users="*" roles="" verbs="" />
        <add accessType="Deny" users="*" />
      </authorization>
    </security>
    
    <!-- Custom 403 error page (optional) -->
    <httpErrors errorMode="Custom">
      <remove statusCode="403" subStatusCode="-1" />
      <error statusCode="403" path="/errors/403.html" responseMode="File" />
    </httpErrors>
  </system.webServer>
</configuration>

<!-- 
Explanation:
- Users CANNOT access cache files via browser (403 Forbidden)
- PHP scripts CAN still read/write cache files from server-side
- Only fetch-program-content.php and program-list.php serve cached data
-->
